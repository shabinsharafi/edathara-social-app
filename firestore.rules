rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      // Only admins can set isAdmin field
      allow update: if isAdmin();
    }

    // ── Grounds ────────────────────────────────────────────────────────────
    match /grounds/{groundId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Bookings ───────────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuth() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() ||
        (isOwner(resource.data.userId) &&
         request.resource.data.status == 'cancelled');
      allow delete: if isAdmin();
    }

    // ── News ───────────────────────────────────────────────────────────────
    match /news/{postId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if isAuth() &&
        // Only allow updating likedBy field for regular users
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy']);
      allow update: if isAdmin(); // Admin can update anything
      allow delete: if isAdmin();
    }

    // ── Fundraisers ────────────────────────────────────────────────────────
    match /fundraisers/{fundId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Feedback ───────────────────────────────────────────────────────────
    match /feedback/{fbId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Contacts ───────────────────────────────────────────────────────────
    match /contacts/{contactId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Banners ────────────────────────────────────────────────────────────
    match /banners/{bannerId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}
