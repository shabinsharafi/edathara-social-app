rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function hasTournamentAccess() {
      return isAuth() && (
        isAdmin() ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('tournamentAccess', false) == true
      );
    }

    function isScorekeeper(tournamentId) {
      return isAuth() &&
        (request.auth.uid in
          get(/databases/$(database)/documents/tournaments/$(tournamentId)).data.get('scorekeeperUids', []));
    }

    function canWriteTournament(tournamentId) {
      return isAdmin() || isScorekeeper(tournamentId);
    }

    // ── Users ──────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
    }

    // ── Grounds ────────────────────────────────────────────────────────────
    match /grounds/{groundId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Bookings ───────────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuth() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() ||
        (isOwner(resource.data.userId) &&
         request.resource.data.status == 'cancelled');
      allow delete: if isAdmin();
    }

    // ── News ───────────────────────────────────────────────────────────────
    match /news/{postId} {
      allow read: if isAuth();
      allow create: if isAdmin();
      allow update: if isAdmin() ||
        (isAuth() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy']));
      allow delete: if isAdmin();
    }

    // ── Fundraisers ────────────────────────────────────────────────────────
    match /fundraisers/{fundId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Feedback ───────────────────────────────────────────────────────────
    match /feedback/{fbId} {
      allow read: if isAdmin();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Contacts ───────────────────────────────────────────────────────────
    match /contacts/{contactId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Banners ────────────────────────────────────────────────────────────
    match /banners/{bannerId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Tournaments + subcollections ───────────────────────────────────────
    match /tournaments/{tournamentId} {
      allow read: if hasTournamentAccess();
      allow create: if isAdmin();
      allow update: if canWriteTournament(tournamentId);
      allow delete: if isAdmin();

      match /teams/{teamId} {
        allow read: if hasTournamentAccess();
        allow create: if canWriteTournament(tournamentId);
        allow update: if canWriteTournament(tournamentId);
        allow delete: if isAdmin();
      }

      match /players/{playerId} {
        allow read: if hasTournamentAccess();
        allow create: if canWriteTournament(tournamentId);
        allow update: if canWriteTournament(tournamentId);
        allow delete: if isAdmin();
      }

      match /fixtures/{fixtureId} {
        allow read: if hasTournamentAccess();
        allow create: if canWriteTournament(tournamentId);
        allow update: if canWriteTournament(tournamentId);
        allow delete: if isAdmin();
      }
    }

    // ── Cricket Innings ────────────────────────────────────────────────────
    match /cricketInnings/{inningsId} {
      allow read: if hasTournamentAccess();
      allow create: if isAdmin() || isScorekeeper(request.resource.data.tournamentId);
      allow update: if isAdmin() || isScorekeeper(resource.data.tournamentId);
      allow delete: if isAdmin();
    }

    // ── Batting Scores ─────────────────────────────────────────────────────
    match /battingScores/{scoreId} {
      allow read: if hasTournamentAccess();
      allow create: if isAdmin() || isScorekeeper(request.resource.data.tournamentId);
      allow update: if isAdmin() || isScorekeeper(resource.data.tournamentId);
      allow delete: if isAdmin();
    }

    // ── Bowling Figures ────────────────────────────────────────────────────
    match /bowlingFigures/{figureId} {
      allow read: if hasTournamentAccess();
      allow create: if isAdmin() || isScorekeeper(request.resource.data.tournamentId);
      allow update: if isAdmin() || isScorekeeper(resource.data.tournamentId);
      allow delete: if isAdmin();
    }
  }
}
